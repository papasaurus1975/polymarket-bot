# === System Mode ===
APP_MODE=research                  # research | paper | semi_auto | live
SIMPLE_MODE=true                   # true = SQLite + APScheduler
LIVE_TRADING_ENABLED=false         # master live trading switch
COMPLIANCE_APPROVED=false          # must be set manually

# === Infrastructure ===
DATABASE_URL=                      # postgres://... (SIMPLE_MODE=false only)
REDIS_URL=                         # redis://... (SIMPLE_MODE=false only)

# === Polymarket ===
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_FUNDER_ADDRESS=         # Polygon wallet address
POLYGON_KEYSTORE_PATH=             # path to encrypted keystore file
POLYGON_KEYSTORE_PASSPHRASE=       # use secrets manager in production

# === External Data Feeds ===
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINGECKO_API_KEY=                 # optional, increases rate limit
DERIBIT_API_KEY=                   # optional, for implied vol
CRYPTOPANIC_API_KEY=               # for news feed

# === AI ===
OPENAI_API_KEY=
AI_SCORING_ENABLED=true            # set false to disable AI layer entirely

# === Risk Limits ===
MAX_POSITION_SIZE_PCT=0.01
MAX_MARKET_EXPOSURE_PCT=0.05
MAX_SECTOR_EXPOSURE_PCT=0.20
MAX_DAILY_LOSS_PCT=0.03
MAX_WEEKLY_LOSS_PCT=0.07
MAX_OPEN_POSITIONS=20
MIN_EDGE=0.07
MIN_LIQUIDITY=1000
MAX_SPREAD=0.05
MIN_RESOLUTION_SOURCE_SCORE=0.40

# === Reconnection & Reliability ===
WEBSOCKET_MAX_RETRIES=5
RECONCILIATION_INTERVAL_MINUTES=5
DATA_FEED_FALLBACK_ENABLED=true

# === Logging ===
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/bot.log
